{
    "manifest_version": 3,
    "name": "Khukri Download Interceptor",
    "version": "0.1.0",
    "description": "Intercepts downloads and hands off to Khukri Native Messaging bridge.",
    "permissions": [
        "downloads",
        "nativeMessaging",
        "storage",
        "webRequest",
        "scripting"
    ],
    "optional_host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "service-worker.js"
    },
    "action": {
        "default_title": "Khukri Download Manager"
    }
}
