{
    "manifest_version": 3,
    "name": "Khukri Download Interceptor",
    "version": "0.1.0",
    "description": "Intercepts downloads and hands off to Khukri Native Messaging bridge.",
    "permissions": [
        "downloads",
        "nativeMessaging",
        "storage",
        "webRequest"
    ],
    "background": {
        "service_worker": "service-worker.js"
    },
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_title": "Khukri Download Manager"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-script.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "blade-ui.js"
            ],
            "run_at": "document_idle",
            "all_frames": true
        }
    ]
}
