{
    "manifest_version": 3,
    "name": "Khukri Download Interceptor",
    "version": "0.1.0",
    "description": "Intercepts downloads and hands off to Khukri Native Messaging bridge.",
    "permissions": [
        "downloads",
        "nativeMessaging",
        "storage",
        "webRequest",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-script-main.js"
            ],
            "run_at": "document_start",
            "world": "MAIN",
            "all_frames": false
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content-script.js",
                "blade-ui.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ],
    "background": {
        "service_worker": "service-worker.js"
    },
    "action": {
        "default_title": "Khukri Download Manager"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "prompt.html",
                "prompt.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}
