{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Khukri",
  "version": "0.1.0",
  "identifier": "com.khukri.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Khukri",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "externalBin": [
      "../sidecar/yt-dlp"
    ],
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
