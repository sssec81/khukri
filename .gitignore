# Rust / Cargo
target/

# SQLite state databases (runtime artifacts)
*.db
*.db-shm
*.db-wal

# sqlx offline cache (generated, not needed in repo yet)
.sqlx/

# Tauri (Sprint 3+)
src-tauri/target/
dist/
.tauri/

# Node / Extension (Sprint 2+)
node_modules/
extension/dist/
extension/.cache/

# Generated native messaging manifest — created by register-host.{sh,ps1} at install time.
# Must not be committed: contains an absolute binary path and the real extension ID.
extension/com.khukri.host.json

# Sidecar binaries (Sprint 4+) — tracked by version file, not the binary
sidecar/yt-dlp
sidecar/yt-dlp.exe
sidecar/ffmpeg
sidecar/ffmpeg.exe

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo

# Env / secrets — never commit
.env
.env.*
secrets/

# CI signing artifacts
*.pfx
*.p12
*.cer

# Local download benchmark artifacts
tmp/
.tmpdebug-download.bin

# FFmpeg sidecars — too large for git, fetch via sidecar/fetch-ffmpeg.sh
sidecar/ffmpeg-*
